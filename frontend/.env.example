# Firebase Web SDK (from Firebase Console > Project Settings > Your apps)
# Copy this file to .env and fill in values from the firebaseConfig block.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=tthp-ec0a9.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tthp-ec0a9
VITE_FIREBASE_STORAGE_BUCKET=tthp-ec0a9.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Realtime Database URL (required for RTDB sync)
VITE_FIREBASE_DATABASE_URL=https://tthp-ec0a9-default-rtdb.asia-southeast1.firebasedatabase.app

# Render backend URL (no trailing slash). Leave empty for local dev (Vite proxies /api).
# Example: https://tthp-api.onrender.com
VITE_API_URL=
